{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A storage request lead",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full Name" },
        "phone": { "type": "string", "description": "Phone Number" },
        "email": { "type": "string", "description": "Email Address" },
        "storageNeeds": { "type": "string", "description": "Storage Needs" },
        "userType": { "type": "string", "description": "User Type" },
        "inquiry": { "type": "string", "description": "Optional Inquiry" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission time" },
        "date": { "type": "string", "description": "Submission date (YYYY-MM-DD)" }
      },
      "required": ["name", "phone", "email", "storageNeeds", "userType", "createdAt", "date"]
    },
    "Mail": {
      "title": "Mail",
      "description": "Trigger Email extension document",
      "type": "object",
      "properties": {
        "to": { "type": "array", "items": { "type": "string" }, "description": "Recipient email addresses" },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string", "description": "Email subject" },
            "html": { "type": "string", "description": "Email HTML body" }
          },
          "required": ["subject", "html"]
        }
      },
      "required": ["to", "message"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Storage request leads"
    },
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "Trigger Email queue"
    }
  }
}
